---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { news } from '../data/siteContent';
---

<Layout
  title="News | Bin Naeem Industries"
  description="Latest corporate updates and industry insights from Bin Naeem Industries."
>
  <Header />
  <main class="pt-32 pb-24 bg-white min-h-screen">
    <section class="container-custom">
      <div class="max-w-3xl mb-12">
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tighter text-[#111827] uppercase">News & Insights</h1>
        <p class="mt-4 text-gray-600">Latest updates from across our group companies and operations.</p>
      </div>

      <div class="space-y-8" id="all-news">
        {news.map((item) => (
          <article id={item.slug} class="bg-white border border-gray-100 rounded-3xl p-8 shadow-sm">
            <p class="text-xs font-black tracking-widest text-blue-600 uppercase">{item.category} · {item.date}</p>
            <h2 class="mt-3 text-2xl md:text-3xl font-black tracking-tight text-[#111827]">{item.title}</h2>
            <p class="mt-4 text-gray-600">
              Detailed release for this item can be requested through the group communications desk at
              <a href="mailto:info@binnaeem.com" class="text-[#111827] font-semibold"> info@binnaeem.com</a>.
            </p>
          </article>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
