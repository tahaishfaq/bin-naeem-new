---
---

<section id="newsletter" data-theme="light" class="py-20 md:py-24 bg-white">
  <div class="container-custom">
    <div class="relative overflow-hidden rounded-[2.5rem] border border-blue-100 bg-gradient-to-br from-blue-50 via-white to-blue-100/70 p-10 md:p-14 lg:p-16">
      <div class="absolute -right-10 -top-10 w-60 h-60 rounded-full bg-blue-500/10 blur-3xl"></div>
      <div class="absolute -left-20 -bottom-16 w-72 h-72 rounded-full bg-blue-300/20 blur-3xl"></div>

      <div class="relative z-10 grid grid-cols-1 lg:grid-cols-[1.2fr_1fr] gap-10 items-end">
        <div class="space-y-5">
          <div class="section-chip">
            <span class="section-chip-dot"></span>
            Newsletter
          </div>
          <h3 class="text-4xl md:text-5xl font-extrabold tracking-tighter leading-[1.05]">Get Group Updates Directly</h3>
          <p class="text-lg text-gray-600 max-w-2xl">Receive selected business announcements, milestone highlights, and partnership opportunities.</p>
        </div>

        <form class="flex flex-col sm:flex-row gap-4">
          <input type="email" placeholder="Enter your business email" class="w-full sm:flex-1 rounded-2xl border border-blue-200 bg-white/80 px-5 py-4 text-[#111827] placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500/40" />
          <button type="submit" class="rounded-2xl bg-[#111827] text-white px-7 py-4 font-bold tracking-wide hover:bg-[#1f2937] transition-colors">Subscribe</button>
        </form>
      </div>
    </div>
  </div>
</section>
