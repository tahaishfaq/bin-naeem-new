---
const capabilities = [
  {
    title: "Supply Chain Optimization",
    description: "End-to-end management from manufacturing to distribution."
  },
  {
    title: "R&D Excellence",
    description: "Continuous innovation in material science and engineering."
  },
  {
    title: "Global Distribution",
    description: "Strategic logistics network spanning multiple continents."
  },
  {
    title: "Sustainability Focus",
    description: "Commitment to eco-friendly industrial practices."
  }
];
---

<section id="expertise" data-theme="dark" class="relative bg-[#111827] overflow-hidden">
  
  <!-- Premium Background Texture -->
  <div class="absolute inset-0 z-0 opacity-[0.05] pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="container-custom relative z-10">
    <div class="flex flex-col lg:flex-row gap-0">
      
      <!-- Left: Sticky Narrative & Progress (The Vision Pillar) -->
      <div class="lg:w-1/2 lg:h-screen flex flex-col justify-center py-20 lg:py-0 lg:sticky lg:top-0">
        <div class="space-y-12 max-w-md" data-reveal-capabilities-vision>
          <div class="space-y-6">
            <div class="inline-flex items-center gap-3 px-4 py-1.5 rounded-full bg-white/5 text-[10px] font-black tracking-widest text-white/60 uppercase border border-white/10">
              <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>
              STRATEGIC VISION
            </div>
            
            <h2 class="text-5xl lg:text-7xl font-extrabold leading-[0.95] text-white tracking-tighter uppercase">
              Innovation <br/>
              <span class="text-blue-500">Redefined.</span>
            </h2>
            
            <p class="text-lg text-white/40 font-light leading-relaxed">
              Leveraging advanced engineering and strategic capital to set new benchmarks across global industrial landscapes.
            </p>
          </div>

          <!-- Growth Chain (Visual Progress) -->
          <div class="relative pl-8 space-y-10 group/chain">
            <div class="absolute left-[3px] top-0 w-[2px] h-full bg-white/5">
              <div class="growth-chain-line absolute top-0 left-0 w-full h-0 bg-blue-500 shadow-[0_0_15px_rgba(59,130,246,0.5)] transition-all duration-500"></div>
            </div>
            
            {capabilities.map((item, idx) => (
              <div class="growth-node group/node flex items-center gap-6 cursor-pointer opacity-30 transition-all duration-500" data-node={idx}>
                <div class="w-2 h-2 rounded-full bg-white group-[.active]/node:bg-blue-500 group-[.active]/node:scale-150 transition-all shadow-[0_0_0_4px_rgba(255,255,255,0.05)] group-[.active]/node:shadow-[0_0_15px_rgba(59,130,246,0.5)]"></div>
                <span class="text-[10px] font-black text-white uppercase tracking-[0.2em] group-[.active]/node:text-blue-400">{item.title}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
      
      <!-- Right: Interactive Expertise Stack -->
      <div class="lg:w-1/2 py-20 lg:py-[30vh] flex flex-col gap-32 md:gap-64">
        {capabilities.map((item, idx) => (
          <div class="expertise-card-wrapper h-[400px] md:h-[500px] flex items-center" data-card={idx}>
            <div class="expertise-card group/card relative w-full h-full p-12 rounded-[2.5rem] bg-white/[0.03] border border-white/5 backdrop-blur-xl transition-all duration-700 hover:border-blue-500/30 overflow-hidden flex flex-col justify-end">
              
              <!-- Card Depth Background -->
              <div class="absolute inset-0 bg-gradient-to-br from-blue-600/5 to-transparent opacity-0 group-hover/card:opacity-100 transition-opacity duration-700"></div>
              <div class="absolute -top-24 -right-24 w-64 h-64 bg-blue-600/10 rounded-full blur-[80px] opacity-0 group-hover/card:opacity-100 transition-opacity duration-1000"></div>

              <div class="relative z-10 space-y-6">
                <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-blue-500 group-hover/card:bg-blue-600 group-hover/card:text-white group-hover/card:scale-110 group-hover/card:shadow-2xl group-hover/card:shadow-blue-600/20 transition-all duration-500">
                   <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
                </div>
                
                <h3 class="text-3xl md:text-5xl font-black text-white uppercase tracking-tighter leading-none group-hover/card:text-blue-400 transition-colors duration-500">
                  {item.title}
                </h3>
                
                <p class="text-white/40 text-sm md:text-lg font-light leading-relaxed max-w-md group-hover/card:text-white/60 transition-colors duration-500">
                  {item.description}
                </p>

                <div class="pt-6 border-t border-white/5 flex items-center justify-between">
                   <span class="text-[9px] font-black text-white/20 uppercase tracking-[0.4em]">CAPABILITY 0{idx + 1}</span>
                   <div class="w-10 h-10 rounded-full border border-white/5 flex items-center justify-center text-white/20 group-hover/card:text-blue-500 group-hover/card:border-blue-500 transition-all duration-500">
                      <svg xmlns="http://www.w3.org/1999/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
                   </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initCapabilitiesCinematic() {
    const section = document.getElementById('expertise');
    const cards = document.querySelectorAll('.expertise-card-wrapper');
    const nodes = document.querySelectorAll('.growth-node');
    const chainLine = document.querySelector('.growth-chain-line');

    if (!section || !cards.length) return;

    // 1. Sync Progress Line & Nodes with Scroll
    cards.forEach((card, i) => {
      ScrollTrigger.create({
        trigger: card,
        start: "top center",
        end: "bottom center",
        onToggle: self => {
          if (self.isActive) {
            nodes.forEach(n => n.classList.remove('active'));
            nodes[i].classList.add('active');
            
            // Update progress line height
            const progress = ((i + 1) / cards.length) * 100;
            gsap.to(chainLine, { height: `${progress}%`, duration: 0.8, ease: "power2.out" });
          }
        }
      });

      // 2. Cinematic Card Entry (Aperture Reveal)
      gsap.from(card.querySelector('.expertise-card'), {
        scale: 0.9,
        opacity: 0,
        y: 100,
        filter: 'blur(10px)',
        duration: 1.2,
        ease: "power3.out",
        scrollTrigger: {
          trigger: card,
          start: "top 90%",
          end: "top 40%",
          scrub: true
        }
      });
    });

    // 3. 3D Card Hover Logic (Magnetic Tilt)
    cards.forEach(wrapper => {
      const cardInner = wrapper.querySelector('.expertise-card');
      
      wrapper.addEventListener('mousemove', (e) => {
        const rect = wrapper.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        
        const rotateX = (y - centerY) / 20;
        const rotateY = (centerX - x) / 20;

        gsap.to(cardInner, {
          rotateX: rotateX,
          rotateY: rotateY,
          duration: 0.5,
          ease: "power2.out",
          transformPerspective: 1000
        });
      });

      wrapper.addEventListener('mouseleave', () => {
        gsap.to(cardInner, {
          rotateX: 0,
          rotateY: 0,
          duration: 0.8,
          ease: "elastic.out(1, 0.3)"
        });
      });
    });
  }

  initCapabilitiesCinematic();
  document.addEventListener('astro:after-swap', initCapabilitiesCinematic);
</script>

<style>
  .expertise-card {
    will-change: transform, opacity, filter;
    transform-style: preserve-3d;
  }
  .growth-chain-line {
    will-change: height;
  }
</style>
