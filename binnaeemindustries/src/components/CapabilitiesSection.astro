---
const capabilities = [
  {
    title: "Supply Chain Optimization",
    description: "End-to-end management from manufacturing to distribution."
  },
  {
    title: "R&D Excellence",
    description: "Continuous innovation in material science and engineering."
  },
  {
    title: "Global Distribution",
    description: "Strategic logistics network spanning multiple continents."
  },
  {
    title: "Sustainability Focus",
    description: "Commitment to eco-friendly industrial practices."
  }
];
---

<section id="expertise" data-theme="dark" class="relative py-24 md:py-32 overflow-hidden bg-[#111827]">
  
  <!-- Abstract Premium Glows -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-500/10 rounded-full blur-[120px] -mr-48 -mt-48 opacity-40"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-blue-500/5 rounded-full blur-[100px] -ml-32 -mb-32 opacity-30"></div>

  <div class="container-custom relative z-10">
    <div class="flex flex-col lg:flex-row gap-16 lg:gap-24">
      
      <!-- Left: Narrative -->
      <div class="lg:w-1/3 space-y-8" data-reveal-capabilities-header>
        <div class="inline-flex items-center gap-3 px-4 py-1.5 rounded-full bg-white/5 text-[10px] font-black tracking-widest text-white/60 uppercase border border-white/10">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>
          OUR CAPABILITIES
        </div>
        
        <h2 class="text-4xl lg:text-6xl font-extrabold leading-[1.1] text-white tracking-tighter uppercase relative">
          Innovation <br/>That Drives <br/><span class="text-blue-500">Growth.</span>
        </h2>
        
        <p class="text-lg text-white/40 font-light leading-relaxed">
          Leveraging cutting-edge technology and strategic expertise to redefine industrial standards across the globe.
        </p>

        <div class="pt-4 flex items-center gap-4 group cursor-pointer">
          <div class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center group-hover:bg-blue-600 group-hover:border-blue-500 transition-all duration-500">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-white"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
          </div>
          <span class="text-[10px] font-black text-white/60 uppercase tracking-widest group-hover:text-blue-500 transition-colors">Download Brochure</span>
        </div>
      </div>
      
      <!-- Right: Detailed Expertise List -->
      <div class="lg:w-2/3 grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
        {capabilities.map((item) => (
          <div class="capability-item border-b border-white/5 pb-10 group" data-reveal-capability>
            <div class="flex justify-between items-start mb-6">
              <div class="space-y-4">
                <span class="text-[9px] font-black text-blue-500/40 uppercase tracking-[0.4em] group-hover:text-blue-500 transition-colors duration-500">STRATEGIC PILLAR</span>
                <h3 class="text-xl md:text-2xl font-black text-white group-hover:text-blue-400 transition-all duration-500 uppercase tracking-tight">{item.title}</h3>
              </div>
              <div class="w-10 h-10 rounded-full border border-white/5 flex items-center justify-center text-white/20 group-hover:text-blue-500 group-hover:border-blue-500/30 group-hover:rotate-45 transition-all duration-700">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
              </div>
            </div>
            <p class="text-white/40 text-xs md:text-sm font-light leading-relaxed group-hover:text-white/60 transition-colors duration-500">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initCapabilities() {
    const items = document.querySelectorAll('[data-reveal-capability]');
    const header = document.querySelector('[data-reveal-capabilities-header]');
    const section = document.getElementById('expertise');

    if (!section) return;

    // Header Reveal
    gsap.from(header, {
      y: 40,
      opacity: 0,
      duration: 1.2,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: section,
        start: 'top 80%',
      }
    });

    // Items Staggered Reveal
    gsap.from(items, {
      y: 30,
      opacity: 0,
      duration: 1,
      stagger: 0.15,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: section,
        start: 'top 70%',
      }
    });
  }

  initCapabilities();
  document.addEventListener('astro:after-swap', initCapabilities);
</script>
