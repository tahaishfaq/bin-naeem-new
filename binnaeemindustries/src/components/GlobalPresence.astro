---
// GlobalPresence.astro

const stats = [
  { value: "25+", label: "Countries Served", description: "Global distribution network" },
  { value: "4", label: "Continents", description: "Strategic operational hubs" },
  { value: "200+", label: "Partners", description: "Trusted global alliances" },
];

const locations = [
  { name: "Middle East", top: "45%", left: "60%", delay: "0s" },
  { name: "South Asia", top: "50%", left: "70%", delay: "0.2s" },
  { name: "Europe", top: "35%", left: "48%", delay: "0.4s" },
  { name: "Africa", top: "60%", left: "55%", delay: "0.6s" },
];
---

<section id="global-presence" data-theme="dark" class="relative bg-[#111827] overflow-hidden py-20 md:py-32">
  
  <!-- Premium Background Texture -->
  <div class="absolute inset-0 z-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="container-custom relative z-10">
    <div class="text-center max-w-3xl mx-auto space-y-6 mb-16 md:mb-24" data-reveal-global-header>
      <div class="inline-flex items-center gap-3 px-4 py-1.5 rounded-full bg-white/5 text-[10px] font-black tracking-widest text-white/60 uppercase border border-white/10">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>
        Global Footprint
      </div>
      <h2 class="text-4xl md:text-6xl font-extrabold leading-[1.1] text-white tracking-tighter uppercase stagger-global-header">
        Connecting <br class="hidden md:block" />
        <span class="text-blue-500">Global Markets.</span>
      </h2>
      <p class="text-lg text-white/40 font-light leading-relaxed stagger-global-header">
        Our strategic supply chain and logistics infrastructure bridge continents, delivering industrial excellence to international markets seamlessly.
      </p>
    </div>

    <!-- Map and Stats Layout -->
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center">
      
      <!-- Left: World Map Representation -->
      <div class="w-full lg:w-2/3 h-[300px] md:h-[500px] relative bg-white/[0.02] border border-white/5 rounded-3xl overflow-hidden group">
        <!-- Abstract glowing world background -->
        <div class="absolute inset-0 bg-gradient-to-br from-blue-600/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>
        
        <!-- Simplified abstract grid/map area -->
        <div class="absolute inset-4 border border-white/5 rounded-2xl overflow-hidden" style="background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 20px 20px;">
           <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,#111827_80%)]"></div>
        </div>

        <!-- Location Nodes -->
        {locations.map((loc) => (
          <div class="absolute location-node origin-center" style={`top: ${loc.top}; left: ${loc.left};`}>
            <div class="relative flex items-center justify-center">
              <div class="absolute w-8 h-8 md:w-12 md:h-12 bg-blue-500/20 rounded-full animate-ping" style={`animation-delay: ${loc.delay}`}></div>
              <div class="w-2 h-2 md:w-3 md:h-3 bg-blue-500 rounded-full shadow-[0_0_15px_rgba(59,130,246,0.8)]"></div>
              
              <!-- Tag -->
              <div class="absolute -top-8 left-1/2 -translate-x-1/2 px-3 py-1 bg-[#111827] border border-white/10 rounded-md text-[8px] md:text-[10px] font-bold text-white uppercase tracking-wider whitespace-nowrap opacity-0 -translate-y-2 transition-all duration-300 group-hover:-translate-y-4 group-hover:opacity-100">
                {loc.name}
              </div>
            </div>
          </div>
        ))}
        
        <!-- Animated connection curves (abstract) -->
        <svg class="absolute inset-0 w-full h-full opacity-40 mix-blend-screen pointer-events-none" preserveAspectRatio="none">
          <path d="M 60% 45% Q 65% 30% 70% 50%" fill="none" class="stroke-blue-500/30" stroke-width="1" stroke-dasharray="4 4">
            <animate attributeName="stroke-dashoffset" from="100" to="0" dur="3s" linear infinite />
          </path>
          <path d="M 60% 45% Q 55% 40% 48% 35%" fill="none" class="stroke-blue-500/30" stroke-width="1" stroke-dasharray="4 4">
            <animate attributeName="stroke-dashoffset" from="100" to="0" dur="4s" linear infinite />
          </path>
           <path d="M 60% 45% Q 60% 55% 55% 60%" fill="none" class="stroke-blue-500/30" stroke-width="1" stroke-dasharray="4 4">
            <animate attributeName="stroke-dashoffset" from="100" to="0" dur="5s" linear infinite />
          </path>
        </svg>
      </div>

      <!-- Right: Stats -->
      <div class="w-full lg:w-1/3 space-y-6" data-reveal-global-stats>
        {stats.map((stat, idx) => (
          <div class="global-stat-card p-6 md:p-8 rounded-[2rem] bg-white/[0.03] border border-white/5 backdrop-blur-md transition-all duration-500 hover:bg-white/[0.05] hover:border-blue-500/30">
            <div class="text-4xl md:text-5xl font-black text-white mb-2 tracking-tighter counter-value">
              {stat.value}
            </div>
            <h4 class="text-sm md:text-base font-bold text-blue-400 uppercase tracking-widest mb-1">
              {stat.label}
            </h4>
            <p class="text-xs md:text-sm text-white/40 font-light">
              {stat.description}
            </p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  .location-node {
    will-change: transform;
  }
  .global-stat-card {
    will-change: transform, opacity;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initGlobalPresence() {
    const section = document.getElementById('global-presence');
    if (!section) return;

    // Header Reveal
    gsap.from('.stagger-global-header', {
      y: 30,
      opacity: 0,
      duration: 1,
      stagger: 0.15,
      ease: "power3.out",
      scrollTrigger: {
        trigger: section,
        start: "top 80%",
      }
    });

    // Stats Stagger Reveal
    gsap.from('.global-stat-card', {
      x: 30,
      opacity: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: "power2.out",
      scrollTrigger: {
        trigger: '[data-reveal-global-stats]',
        start: "top 85%",
      }
    });

    // Map Nodes Pop-in
    gsap.fromTo('.location-node', 
      { scale: 0, opacity: 0 },
      {
        scale: 1,
        opacity: 1,
        duration: 0.8,
        stagger: 0.2,
        ease: "back.out(1.7)",
        scrollTrigger: {
          trigger: section,
          start: "top 60%",
        }
      }
    );
  }

  // Handle both initial load and Astro transitions
  const runInit = () => setTimeout(initGlobalPresence, 200);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', runInit);
  } else {
    runInit();
  }
  
  document.addEventListener('astro:after-swap', runInit);
</script>
