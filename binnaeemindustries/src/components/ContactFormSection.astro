---
---

<section id="contact" data-theme="light" class="py-20 md:py-24 bg-white">
  <div class="container-custom">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.1fr] gap-10 lg:gap-14 items-start">
      <div class="space-y-6">
        <div class="section-chip">
          <span class="section-chip-dot"></span>
          Contact Us
        </div>
        <h3 class="text-4xl md:text-6xl font-extrabold tracking-tighter leading-[1.02]">Start a Premium Partnership Conversation</h3>
        <p class="text-lg text-gray-600">Share your requirement and our team will connect with the relevant business unit.</p>
      </div>

      <form class="rounded-[2rem] border border-blue-100 bg-white p-7 md:p-9 shadow-[0_20px_45px_rgba(30,64,175,0.08)] space-y-5">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <input type="text" placeholder="Full Name" class="rounded-xl border border-gray-200 px-4 py-3.5 focus:outline-none focus:ring-2 focus:ring-blue-500/35" />
          <input type="email" placeholder="Business Email" class="rounded-xl border border-gray-200 px-4 py-3.5 focus:outline-none focus:ring-2 focus:ring-blue-500/35" />
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <input type="text" placeholder="Company" class="rounded-xl border border-gray-200 px-4 py-3.5 focus:outline-none focus:ring-2 focus:ring-blue-500/35" />
          <input type="text" placeholder="Phone" class="rounded-xl border border-gray-200 px-4 py-3.5 focus:outline-none focus:ring-2 focus:ring-blue-500/35" />
        </div>
        <textarea rows="5" placeholder="Tell us about your project or requirement" class="w-full rounded-xl border border-gray-200 px-4 py-3.5 focus:outline-none focus:ring-2 focus:ring-blue-500/35"></textarea>
        <button type="submit" class="w-full rounded-xl bg-[#111827] text-white py-3.5 font-bold tracking-wide hover:bg-[#1f2937] transition-colors">Submit Inquiry</button>
      </form>
    </div>
  </div>
</section>
