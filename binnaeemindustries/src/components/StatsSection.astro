---
const stats = [
  { label: "Years of Experience", value: "25+" },
  { label: "Companies Under Group", value: "12" },
  { label: "Projects Delivered", value: "480+" },
  { label: "Cities Served", value: "15+" }
];
---

<section class="section-padding container-custom">
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-12 text-center" data-reveal>
    {stats.map((stat) => (
      <div class="space-y-4">
        <div class="text-5xl lg:text-6xl font-bold text-[#111827] tracking-tight">{stat.value}</div>
        <p class="text-sm font-medium text-gray-500 uppercase tracking-widest">{stat.label}</p>
      </div>
    ))}
  </div>
</section>
