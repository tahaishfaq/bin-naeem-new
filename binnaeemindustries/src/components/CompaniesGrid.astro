---
const companies = [
  {
    name: "Naeem Packages",
    industry: "Industrial Manufacturing",
    description: "High-performance industrial packaging solutions for global supply chains.",
    image: "https://images.unsplash.com/photo-1586528116311-ad86d6f5fbdf?auto=format&fit=crop&q=80&w=800"
  },
  {
    name: "Hanplas Machinery",
    industry: "Engineering & Machinery",
    description: "State-of-the-art machinery and technical engineering services.",
    image: "https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&q=80&w=800"
  },
  {
    name: "Box Pack",
    industry: "Packaging & Logistics",
    description: "Next-generation corrugated solutions and protective logistics material.",
    image: "https://images.unsplash.com/photo-1595246140625-573b715d11dc?auto=format&fit=crop&q=80&w=800"
  },
  {
    name: "Mondsub",
    industry: "Consumer Retail Brands",
    description: "Premium personal care and consumer products for the modern lifestyle.",
    image: "https://images.unsplash.com/photo-1556228578-0d85b1a4d571?auto=format&fit=crop&q=80&w=800"
  },
  {
    name: "House of Pinatas",
    industry: "Consumer & Events",
    description: "Innovative product design and creative consumer experiences.",
    image: "https://images.unsplash.com/photo-1533219057257-4bb9ed5d2cc6?auto=format&fit=crop&q=80&w=800"
  },
  {
    name: "NS Builders",
    industry: "Construction & Infrastructure",
    description: "Delivering structural excellence and sustainable urban developments.",
    image: "https://images.unsplash.com/photo-1503387762-11a0fcfbd307?auto=format&fit=crop&q=80&w=800"
  }
];
---

<section id="companies" class="section-padding container-custom">
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16" data-reveal>
    <div class="max-w-2xl">
      <h2 class="text-4xl lg:text-5xl font-semibold text-[#111827] mb-4">Our Group Companies</h2>
      <p class="text-lg text-gray-500">A diverse portfolio leading innovation across multiple sectors.</p>
    </div>
    <div>
      <a href="#contact" class="btn-secondary group">
        View All Companies 
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-2 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {companies.map((company) => (
      <div class="card-premium group" data-reveal>
        <div class="aspect-[4/3] overflow-hidden">
          <img 
            src={company.image} 
            alt={company.name} 
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
          />
        </div>
        <div class="p-8">
          <span class="text-[10px] font-bold tracking-widest text-gray-400 uppercase mb-3 block">{company.industry}</span>
          <h3 class="text-xl font-bold text-[#111827] mb-3">{company.name}</h3>
          <p class="text-gray-500 text-sm leading-relaxed mb-6">{company.description}</p>
          <a href="#" class="inline-flex items-center text-xs font-semibold text-[#111827] hover:gap-2 transition-all">
            Learn More 
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 ml-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </div>
      </div>
    ))}
  </div>
</section>
