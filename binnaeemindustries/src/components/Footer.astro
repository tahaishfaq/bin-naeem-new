---
const currentYear = new Date().getFullYear();
---

<footer class="dark-premium-bg text-white pt-20 pb-10 border-t border-white/10">
  <div class="container-custom space-y-14">
    <div class="rounded-[2rem] border border-white/10 bg-white/[0.03] backdrop-blur-md p-8 md:p-10 flex flex-col lg:flex-row gap-8 lg:items-center lg:justify-between">
      <div class="space-y-3 max-w-2xl">
        <p class="text-xs tracking-[0.3em] uppercase text-blue-300">Bin Naeem Industries</p>
        <h4 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white">Building Industrial Value Across Sectors</h4>
        <p class="text-white/60">Manufacturing, logistics, infrastructure, and portfolio operations under one disciplined group strategy.</p>
      </div>
      <a href="/#contact" class="inline-flex items-center justify-center rounded-2xl bg-white text-[#111827] px-8 py-4 font-bold tracking-wide hover:bg-blue-100 transition-colors">Start a Conversation</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <div>
        <a href="/" class="text-xl font-bold tracking-tight">BIN NAEEM <span class="font-normal text-white/50">INDUSTRIES</span></a>
        <p class="mt-4 text-white/55 text-sm leading-relaxed">A diversified holding company operating with a long-term industrial vision.</p>
      </div>

      <div>
        <h5 class="text-xs font-bold uppercase tracking-[0.25em] text-white/50 mb-4">Explore</h5>
        <ul class="space-y-3 text-sm text-white/70">
          <li><a href="/#about" class="hover:text-white">About</a></li>
          <li><a href="/#companies" class="hover:text-white">Companies</a></li>
          <li><a href="/#industries" class="hover:text-white">Industries</a></li>
          <li><a href="/#news" class="hover:text-white">News</a></li>
        </ul>
      </div>

      <div>
        <h5 class="text-xs font-bold uppercase tracking-[0.25em] text-white/50 mb-4">Contact</h5>
        <ul class="space-y-3 text-sm text-white/70">
          <li>Karachi, Pakistan</li>
          <li><a href="mailto:info@binnaeem.com" class="hover:text-white">info@binnaeem.com</a></li>
          <li><a href="tel:+922134567890" class="hover:text-white">+92 21 3456 7890</a></li>
        </ul>
      </div>

      <div>
        <h5 class="text-xs font-bold uppercase tracking-[0.25em] text-white/50 mb-4">Policies</h5>
        <ul class="space-y-3 text-sm text-white/70">
          <li><a href="/privacy-policy" class="hover:text-white">Privacy Policy</a></li>
          <li><a href="/terms-of-service" class="hover:text-white">Terms of Service</a></li>
          <li><a href="/cookie-policy" class="hover:text-white">Cookie Policy</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-6 border-t border-white/10 flex flex-col md:flex-row gap-4 md:items-center md:justify-between">
      <p class="text-xs text-white/45">© {currentYear} Bin Naeem Industries. All rights reserved.</p>
      <p class="text-xs text-white/35">Powering industries with disciplined execution.</p>
    </div>
  </div>
</footer>
