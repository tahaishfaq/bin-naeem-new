---
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#111827] text-white pt-24 pb-12">
  <div class="container-custom">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 mb-20">
      <div class="space-y-8">
