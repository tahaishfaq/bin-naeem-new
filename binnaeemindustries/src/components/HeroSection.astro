---
const bannerImages = [
  "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&q=80&w=1920",
  "https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&q=80&w=1920",
  "https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&q=80&w=1920",
  "https://images.unsplash.com/photo-1531206715517-5c0ba140b2b8?auto=format&fit=crop&q=80&w=1920",
  "https://images.unsplash.com/photo-1516937941344-00b4e0337589?auto=format&fit=crop&q=80&w=1920"
];
---

<section id="hero" data-theme="dark" class="relative h-[100vh] w-full overflow-hidden dark-premium-bg">
  
  <!-- Cinematic Background Slider (Layers) -->
  <div id="hero-slider" class="absolute inset-0 w-full h-full z-0 overflow-hidden pointer-events-none">
    {bannerImages.map((img, index) => (
      <div 
        class={`absolute inset-0 w-full h-full transition-all duration-2000 cubic-bezier(0.16, 1, 0.3, 1) transform ${index === 0 ? 'opacity-100 scale-100 rotate-0' : 'opacity-0 scale-110 rotate-1'}`}
        data-index={index}
      >
        <img 
          src={img} 
          alt={`Bin Naeem Group Industrial ${index + 1}`} 
          class="w-full h-full object-cover parallax-bg brightness-[0.8] contrast-[1.1]"
        />
        <!-- Multi-stage Gradients for Depth -->
        <div class="absolute inset-0 bg-gradient-to-r from-[#111827] via-transparent to-transparent opacity-80"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-[#111827] via-[#111827]/30 to-transparent"></div>
        <div class="absolute inset-0 bg-[#111827]/20 mix-blend-multiply"></div>
      </div>
    ))}
  </div>

  <!-- Design Flourishes (Lens Flares & Light Leaks) -->
  <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-blue-500/10 rounded-full blur-[120px] animate-flare z-10 pointer-events-none"></div>
  <div class="absolute bottom-[-15%] right-[-5%] w-[40%] h-[60%] bg-blue-500/10 rounded-full blur-[100px] animate-flare delay-1000 z-10 pointer-events-none"></div>
  
  <!-- Content Layout (Asymmetric) -->
  <div class="relative z-20 h-full flex flex-col justify-center">
    <div class="container-custom py-12 md:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
        
        <!-- Left Column: Primary Content -->
        <div class="lg:col-span-8 space-y-8 md:space-y-12" data-reveal>
          <div class="space-y-6">
            <div class="inline-flex items-center gap-4 px-5 py-2 rounded-full glass-premium text-[11px] font-bold tracking-[0.4em] text-white/90 uppercase stagger-item">
              <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
              BIN NAEEM INDUSTRIES (PVT.) Ltd.
            </div>

            <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-[5.5rem] font-black tracking-tight text-white leading-[1.1] md:leading-[1]">
              <span class="block stagger-item">
                Strategic <span class="text-white/60">Leadership</span>
              </span>
              <span class="block stagger-item mt-2">
                 Industrial <span class="italic font-light opacity-90 underline decoration-white/10 underline-offset-[14px]">Future.</span>
              </span>
            </h1>

            <div class="space-y-6 max-w-xl">
              <p class="text-base md:text-lg lg:text-xl text-white/50 leading-relaxed font-light stagger-item opacity-0 transition-opacity duration-1000 delay-300">
                As a leading diversified holding company, we orchestrate specialized industries across <strong>manufacturing, logistics, and infrastructure</strong> to drive Pakistan’s economic engine.
              </p>
              
              <div class="flex items-center gap-6 text-[10px] font-bold text-white/30 uppercase tracking-[0.3em] stagger-item opacity-0 transition-opacity duration-1000 delay-400">
                 <span class="hover:text-white transition-colors cursor-default">Empowering</span>
                 <span class="hover:text-white transition-colors cursor-default">Strengthening</span>
                 <span class="hover:text-white transition-colors cursor-default">Building</span>
              </div>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row items-center gap-6 stagger-item opacity-0 transition-opacity duration-1000 delay-500">
            <a href="#companies" class="group relative px-10 py-5 bg-white text-[#111827] rounded-full text-xs font-black uppercase tracking-widest transition-all duration-500 hover:shadow-[0_0_40px_rgba(255,255,255,0.3)] hover:-translate-y-1">
              Explore Our Companies
              <span class="absolute inset-0 rounded-full border border-white/50 scale-100 opacity-0 group-hover:scale-125 group-hover:opacity-100 transition-all duration-700"></span>
            </a>
            <a href="#contact" class="px-10 py-5 glass-premium border-white/20 text-white rounded-full text-xs font-black uppercase tracking-widest hover:bg-white/10 transition-all duration-500">
              Contact the Group
            </a>
          </div>
        </div>

        <!-- Right Column: Secondary Info (Floating Badges) -->
        <div class="lg:col-span-4 flex lg:flex-col items-center lg:items-end gap-4 lg:gap-8 pb-4" data-reveal>
          {[
            { label: "Multi-Sector", value: "Industrial Portfolio" },
            { label: "Nationwide", value: "Operational Reach" },
            { label: "Strategic", value: "Growth Capital" }
          ].map((item, i) => (
            <div 
              class={`glass-premium-dark p-6 rounded-3xl w-full max-w-[240px] group stagger-item delay-[${600 + (i * 100)}ms]`}
            >
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-white/40 group-hover:text-white transition-colors duration-500">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </div>
                <div>
                  <p class="text-[9px] font-black text-white/30 uppercase tracking-[0.2em]">{item.label}</p>
                  <p class="text-xs font-bold text-white tracking-widest">{item.value}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Scroll & Info -->
  <div class="absolute bottom-12 left-0 w-full px-6 md:px-12 flex justify-between items-end z-30">
    <!-- Hidden SEO Context (Visible but discrete) -->
    <div class="hidden lg:block max-w-sm stagger-item opacity-0 transition-opacity duration-1000 delay-1000" data-reveal>
      <p class="text-[9px] text-white/20 leading-loose uppercase tracking-widest font-black">
        Bin Naeem Industries (Pvt.) Ltd. is a diversified industrial holding company in Pakistan operating across core sectors.
      </p>
    </div>

    <!-- Active Slider Indicators -->
    <div class="flex items-center gap-8">
       <div class="flex gap-4">
        {bannerImages.map((_, index) => (
          <button 
            class={`indicator-dot w-8 h-[2px] rounded-full transition-all duration-700 ${index === 0 ? 'bg-white' : 'bg-white/20'}`}
            data-indicator={index}
            aria-label={`Go to slide ${index + 1}`}
          ></button>
        ))}
      </div>
      <a href="#about" class="group flex items-center gap-4 text-white/30 hover:text-white transition-all">
        <span class="text-[9px] font-black tracking-[0.5em] uppercase">Scroll</span>
        <div class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center group-hover:border-white/40 group-hover:translate-y-1 transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m19 9-7 7-7-7"/></svg>
        </div>
      </a>
    </div>
  </div>

</section>

<style>
  .parallax-bg {
    will-change: transform;
  }

  /* Stagger Reveal System Override - Now handled by GSAP for better perf */
  .stagger-item {
    opacity: 0;
    transform: translateY(30px);
  }

  /* Slider Transitions */
  #hero-slider > div {
    transition: opacity 2s cubic-bezier(0.16, 1, 0.3, 1), transform 2.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function setupHero() {
    const cleanupKey = '__bniHeroCleanup';
    const previousCleanup = (window as any)[cleanupKey];
    if (typeof previousCleanup === 'function') previousCleanup();

    const sliderItems = document.querySelectorAll('#hero-slider > div');
    const indicators = document.querySelectorAll('[data-indicator]');
    const parallaxImages = document.querySelectorAll('.parallax-bg');
    const heroSection = document.getElementById('hero');
    const revealItems = document.querySelectorAll('.stagger-item');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const clickHandlers: Array<{ el: Element; handler: EventListener }> = [];
    const localTriggers: ScrollTrigger[] = [];
    
    if (!sliderItems.length || !indicators.length || !heroSection) return;

    let currentIndex = 0;
    const interval = 7000;

    // Premium Reveal Animation
    if (prefersReducedMotion) {
      gsap.set(revealItems, { y: 0, opacity: 1 });
    } else {
      gsap.to(revealItems, {
        y: 0,
        opacity: 1,
        duration: 1.2,
        stagger: 0.15,
        ease: 'power3.out',
        delay: 0.5
      });
    }

    // GPU-Accelerated Parallax
    if (!prefersReducedMotion) {
      parallaxImages.forEach((img) => {
        const tween = gsap.to(img, {
          y: '20%',
          ease: 'none',
          scrollTrigger: {
            trigger: heroSection,
            start: 'top top',
            end: 'bottom top',
            scrub: true
          }
        });
        if (tween.scrollTrigger) localTriggers.push(tween.scrollTrigger);
      });
    }

    function showSlide(index) {
      if (index === currentIndex) return;

      sliderItems[currentIndex].classList.remove('opacity-100', 'scale-100', 'rotate-0');
      sliderItems[currentIndex].classList.add('opacity-0', 'scale-110', 'rotate-1');
      indicators[currentIndex].classList.remove('bg-white');
      indicators[currentIndex].classList.add('bg-white/20');

      sliderItems[index].classList.remove('opacity-0', 'scale-110', 'rotate-1');
      sliderItems[index].classList.add('opacity-100', 'scale-100', 'rotate-0');
      indicators[index].classList.remove('bg-white/20');
      indicators[index].classList.add('bg-white');
      
      currentIndex = index;
    }

    function showNext() {
      const nextIndex = (currentIndex + 1) % sliderItems.length;
      showSlide(nextIndex);
    }

    indicators.forEach((indicator, index) => {
      const handler = () => {
        showSlide(index);
        if (!prefersReducedMotion) resetTimer();
      };
      indicator.addEventListener('click', handler);
      clickHandlers.push({ el: indicator, handler });
    });

    let autoSlideTimer: ReturnType<typeof setInterval> | null = prefersReducedMotion ? null : setInterval(showNext, interval);

    function resetTimer() {
      if (!autoSlideTimer) return;
      clearInterval(autoSlideTimer);
      autoSlideTimer = setInterval(showNext, interval);
    }

    (window as any)[cleanupKey] = () => {
      if (autoSlideTimer) clearInterval(autoSlideTimer);
      clickHandlers.forEach(({ el, handler }) => el.removeEventListener('click', handler));
      localTriggers.forEach((trigger) => trigger.kill());
    };
  }

  setupHero();
  document.addEventListener('astro:after-swap', setupHero);
</script>
