---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy | Bin Naeem Industries" description="Privacy policy for Bin Naeem Industries website.">
  <main class="container-custom py-20 md:py-24">
    <h1 class="text-3xl md:text-5xl font-extrabold tracking-tighter text-[#111827] uppercase">Privacy Policy</h1>
    <p class="mt-6 text-gray-600 max-w-3xl">We collect contact details submitted via inquiry channels only for communication related to business inquiries. We do not sell personal data and process information for operational and compliance purposes.</p>
  </main>
</Layout>
