---
// Sustainability.astro

const initiatives = [
  {
    title: 'Eco-Industrial Parks',
    subtitle: 'Net-Zero Infrastructure',
    description: 'Developing self-sustaining manufacturing hubs powered by renewable energy and zero-waste systems.',
    keywords: 'Renewables • Waste Reduction • Circular Systems',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"></path><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>`
  },
  {
    title: 'Resilient Supply Chain',
    subtitle: 'Operational Continuity',
    description: 'Optimizing logistics to minimize carbon footprint across all operational verticals.',
    keywords: 'Low Carbon • Route Optimization • Efficiency',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path></svg>`
  },
  {
    title: 'Sustainable Packaging',
    subtitle: 'Material Innovation',
    description: 'Pioneering biodegradable and recyclable materials for global FMCG distribution.',
    keywords: 'Biodegradable • Recyclable • FMCG Grade',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>`
  }
];
---

<section id="sustainability" data-theme="light" class="relative bg-white overflow-hidden py-24 md:py-32">
  <div class="container-custom relative z-10">
    <div class="max-w-3xl mb-16 md:mb-20 space-y-6" data-reveal-sustain-text>
      <div class="section-chip">
        <span class="section-chip-dot"></span>
        Sustainability & ESG
      </div>

      <p class="text-[11px] font-black tracking-[0.35em] text-blue-600 uppercase stagger-sustain-text">Long-Term Responsibility</p>

      <h2 class="text-4xl md:text-6xl font-extrabold leading-[1.05] text-[#111827] tracking-tighter uppercase stagger-sustain-text">
        Engineering a <br />
        <span class="text-blue-600">Resilient Tomorrow.</span>
      </h2>

      <p class="text-lg text-gray-500 font-light leading-relaxed max-w-2xl stagger-sustain-text">
        At Bin Naeem Industries, sustainability is integrated into decision-making, operations, and product strategy to create durable long-term value.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8" data-reveal-sustain-cards>
      {initiatives.map((item) => (
        <article class="sustain-card group h-full">
          <div class="relative h-full p-8 rounded-[2.5rem] bg-[#111827] border border-white/10 backdrop-blur-xl transition-all duration-700 group-hover:bg-[#1f2937] group-hover:border-blue-500/30 group-hover:-translate-y-2 flex flex-col">
            <div class="absolute inset-0 rounded-[2.5rem] bg-gradient-to-br from-blue-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

            <div class="relative z-10 h-full flex flex-col">
              <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 text-blue-400 flex items-center justify-center mb-7">
                <Fragment set:html={item.icon} />
              </div>

              <span class="text-[10px] font-black tracking-[0.3em] text-blue-400 uppercase mb-3 block">{item.subtitle}</span>

              <h3 class="text-2xl md:text-3xl font-black text-white tracking-tight mb-4 uppercase leading-tight">{item.title}</h3>

              <p class="text-white/55 text-base font-light leading-relaxed mb-8 flex-grow">{item.description}</p>

              <div class="w-full pt-4 border-t border-white/10 flex items-center justify-between mt-auto">
                <span class="text-[9px] font-bold text-white/30 uppercase tracking-widest">{item.keywords}</span>
                <div class="text-blue-500 transition-transform group-hover:translate-x-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="7" x2="7" y2="17"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initSustainability() {
    const section = document.getElementById('sustainability');
    if (!section) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    gsap.from('.stagger-sustain-text', {
      y: 24,
      opacity: 0,
      duration: 0.9,
      stagger: 0.12,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '[data-reveal-sustain-text]',
        start: 'top 82%'
      }
    });

    gsap.from('.sustain-card', {
      y: prefersReducedMotion ? 0 : 20,
      opacity: 0,
      duration: 0.75,
      stagger: 0.1,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '[data-reveal-sustain-cards]',
        start: 'top 85%'
      }
    });
  }

  const runInit = () => setTimeout(initSustainability, 180);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', runInit);
  } else {
    runInit();
  }

  document.addEventListener('astro:after-swap', runInit);
</script>
