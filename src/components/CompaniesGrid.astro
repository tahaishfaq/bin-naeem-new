---
import { Image } from 'astro:assets';
import { companies } from '../data/siteContent';
---

<section id="companies" data-theme="dark" class="relative overflow-hidden bg-white">
  <!-- Horizontal Scroll Container -->
  <div class="section-container dark-premium-bg">
    <div class="h-screen flex items-center overflow-hidden pt-20">
      
      <!-- Static Content (Left Side) -->
      <div class="container-custom relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-12 pointer-events-none">
        <div class="lg:col-span-4 space-y-6 pointer-events-auto p-8 lg:p-0">
          <div class="section-chip-dark">
            <span class="section-chip-dot"></span>
            OUR COMPANIES
          </div>
          <h2 class="text-4xl lg:text-7xl font-black text-white leading-tight tracking-tight uppercase">
            Our Group <br/><span class="text-blue-500">Portfolio</span>
          </h2>
          <p class="text-lg text-white/40 font-light leading-relaxed max-w-sm">
            Bin Naeem Industries operates a portfolio of specialized companies that collectively drive growth across key industrial sectors.
          </p>
          
          <div class="pt-8">
             <a href="#contact" class="group relative inline-flex items-center gap-6 px-10 py-5 bg-blue-600 text-white rounded-full text-[11px] font-black uppercase tracking-widest transition-all hover:bg-blue-700 hover:shadow-[0_0_30px_rgba(37,99,235,0.4)] hover:-translate-y-1">
               View All Companies
               <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center group-hover:bg-white/30 transition-colors">
                 <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
               </div>
             </a>
          </div>
        </div>

        <!-- Horizontal Scroll Cards Area -->
        <div class="lg:col-span-8 flex pointer-events-auto h-full items-center">
          <div class="horizontal-scroll-wrapper flex gap-10 px-8 lg:px-20 h-[65vh] items-center">
            {companies.map((v) => (
              <div class="vertical-card shrink-0 w-[300px] md:w-[400px] h-[450px] md:h-[530px] group">
                <div class="relative h-full p-6 md:p-8 rounded-[2.5rem] bg-white/5 border border-white/10 backdrop-blur-xl transition-all duration-700 group-hover:bg-white/10 group-hover:border-blue-500/30 group-hover:-translate-y-4 flex flex-col items-center text-center">
                  
                  <!-- Premium Card Glow -->
                  <div class="absolute inset-0 rounded-[2.5rem] bg-gradient-to-br from-blue-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

                  <div class="relative z-10 h-full flex flex-col items-center">
                    <!-- Logo Container -->
                    <div class="relative w-full h-60 flex items-center justify-center mb-6">
                      <Image 
                        src={v.logo} 
                        alt={v.name} 
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
                      />
                    </div>
                    
                    <span class="text-[10px] font-black tracking-[0.3em] text-blue-400 uppercase mb-3 block">{v.industry}</span>
                    <h3 class="text-xl md:text-2xl font-black text-white mb-4 tracking-tight group-hover:text-blue-400 transition-colors uppercase">{v.name}</h3>
                    <p class="text-white/40 text-[10px] md:text-sm font-light leading-relaxed mb-6 flex-grow">
                      {v.description}
                    </p>

                    <div class="w-full pt-4 border-t border-white/5 flex items-center justify-between mt-auto">
                      <span class="text-[9px] font-bold text-white/20 uppercase tracking-widest">{v.keywords}</span>
                      <div class="text-blue-500 transition-transform group-hover:translate-x-2">
                         <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="7" x2="7" y2="17"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ))}

            <!-- Spacer for scroll ending -->
            <div class="w-[30vw]"></div>
          </div>
        </div>
      </div>

      <!-- Scroll Progress Tracker -->
      <div class="absolute bottom-12 left-1/2 -translate-x-1/2 w-48 h-[2px] bg-white/10 rounded-full overflow-hidden">
        <div id="verticals-progress" class="h-full bg-blue-500 w-0 origin-left"></div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initVerticals() {
    const cleanupKey = '__bniCompaniesCleanup';
    const previousCleanup = (window as any)[cleanupKey];
    if (typeof previousCleanup === 'function') previousCleanup();

    const wrapper = document.querySelector('.horizontal-scroll-wrapper');
    const cards = document.querySelectorAll('.vertical-card');
    const container = document.querySelector('.section-container');
    const progress = document.getElementById('verticals-progress');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const cardTriggers: ScrollTrigger[] = [];

    if (!wrapper || !container) return;

    // Horizontal Scroll Timeline
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: container,
        pin: true,
        scrub: prefersReducedMotion ? false : 1,
        start: "top top",
        end: () => `+=${wrapper.scrollWidth}`,
        invalidateOnRefresh: true,
      }
    });

    tl.to(wrapper, {
      x: () => -(wrapper.scrollWidth - window.innerWidth + 100),
      ease: "none"
    });

    // Update Progress Bar
    tl.to(progress, {
      scaleX: 1,
      ease: "none"
    }, 0);

    // In-card staggering
    cards.forEach((card) => {
      const tween = gsap.from(card, {
        opacity: 0,
        x: 100,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: card,
          containerAnimation: tl,
          start: "left 90%",
          toggleActions: "play none none reverse"
        }
      });
      if (tween.scrollTrigger) cardTriggers.push(tween.scrollTrigger);
    });

    const onResize = () => ScrollTrigger.refresh();
    window.addEventListener('resize', onResize);

    (window as any)[cleanupKey] = () => {
      window.removeEventListener('resize', onResize);
      cardTriggers.forEach((trigger) => trigger.kill());
      tl.scrollTrigger?.kill();
      tl.kill();
    };
  }

  // Handle both initial load and Astro transitions
  initVerticals();
  document.addEventListener('astro:after-swap', initVerticals);
</script>

<style>
  .section-container {
    height: 100vh;
  }
  
  /* Hide scrollbar but keep functionality */
  .horizontal-scroll-wrapper {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .horizontal-scroll-wrapper::-webkit-scrollbar {
    display: none;
  }
</style>
